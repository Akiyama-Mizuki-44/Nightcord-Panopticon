# 复制为 deploy.env 后填真实信息：cp deploy.env.example deploy.env
# deploy.env 不要提交到仓库（已经在 .gitignore 里排除），因为仓库是 public 的，
# 真实的服务器地址/用户名不应该出现在提交历史里。

DEPLOY_USER=mizuki
DEPLOY_HOST=你的服务器地址或IP
# 注意：这里不能写 ~/xxx —— deploy.sh 用 `source` 读这个文件，`~` 会被本地 shell
# 展开成本地的 $HOME，而不是远程服务器的 $HOME，得写远程那边的绝对路径。
DEPLOY_PATH=/home/你的用户名/nightcord-panopticon
DEPLOY_PORT=22

# 同步完是否自动重启远程的 systemd 服务（对应 DEPLOY.zh-CN.md 里配的 nightcord-panopticon.service）
# 还没配 systemd、仍然手动 python app.py 跑的话，改成 false，自己去重启进程。
DEPLOY_RESTART=true
DEPLOY_SERVICE=nightcord-panopticon
